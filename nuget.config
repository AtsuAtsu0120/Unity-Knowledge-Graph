<?xml version="1.0" encoding="utf-8"?>
<!--
  globalPackagesFolder をリポジトリ内に固定する。
  ~/.nuget/packages への書き込みが環境依存で拒否されるため、
  パッケージ復元先を作業ディレクトリ配下に閉じ込めて再現性を確保する。
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <config>
    <add key="globalPackagesFolder" value=".nuget-packages" />
  </config>
</configuration>
